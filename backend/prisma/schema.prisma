datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  FARMER
  BUYER
  EXPORTER
  ADMIN
}

enum OrderStatus {
  PENDING
  ESCROW_FUNDED
  DISPATCHED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  ESCROWED
  RELEASED
  REFUNDED
}

enum AuctionStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SubscriptionTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum NotificationType {
  INFO
  ORDER_UPDATE
  BID_UPDATE
  PAYMENT
  PRICE_ALERT
  MARKET_OPPORTUNITY
  FRAUD_ALERT
  AUCTION_OUTBID
  SYSTEM
}

model MarketReport {
  id          String   @id @default(uuid())
  type        String   // "daily", "weekly", "monthly"
  data        Json
  generatedAt DateTime @default(now())

  @@index([type])
}

model FraudAlert {
  id         String   @id @default(uuid())
  userId     String
  alertType  String   // "FAKE_SELLER", "SUSPICIOUS_PRICING", "ABNORMAL_ACTIVITY", "REVIEW_MANIPULATION"
  severity   String   // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  details    String
  isResolved Boolean  @default(false)
  resolvedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([isResolved])
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String
  role             Role              @default(BUYER)
  trustScore       Float             @default(80.0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  profile          Profile?
  products         Product[]         @relation("SellerProducts")
  ordersAsBuyer    Order[]           @relation("BuyerOrders")
  ordersAsSeller   Order[]           @relation("SellerOrders")
  auctions         Auction[]         @relation("UserAuctions")
  bids             Bid[]             @relation("UserBids")
  reviewsGiven     Review[]          @relation("ReviewsGiven")
  reviewsReceived  Review[]          @relation("ReviewsReceived")
  subscriptions    Subscription[]
  notifications    Notification[]
  messagesSent     Message[]         @relation("MessagesSent")
  messagesReceived Message[]         @relation("MessagesReceived")
  refreshTokens    RefreshToken[]
  chatSessions     ChatSession[]
  auditLogs        AuditLog[]
  transactions     Transaction[]
  savedSearches    SavedSearch[]
  priceAlerts      PriceAlert[]
  buyerNegotiations Negotiation[]    @relation("BuyerNegotiations")
  sellerNegotiations Negotiation[]   @relation("SellerNegotiations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String?
  companyName String?
  address     String?
  city        String?
  country     String?
  avatarUrl   String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum ProductStatus {
  ACTIVE
  SOLD
  ARCHIVED
}

model Product {
  id                 String        @id @default(uuid())
  sellerId           String
  seller             User          @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId         String
  category           Category      @relation(fields: [categoryId], references: [id])
  title              String
  description        String
  price              Float
  unit               String
  stock              Float
  cropType           String
  grade              String
  imageUrl           String?
  sellerVerification String        @default("Standard")
  status             ProductStatus @default(ACTIVE)
  harvestDate        DateTime?
  certificateUrl     String?
  orderItems         OrderItem[]
  negotiations       Negotiation[]
  qualityGrading     QualityGrading?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model MarketRate {
  id            String   @id @default(uuid())
  crop          String   @unique
  priceIndia    Float
  priceDubai    Float
  changeIndia   Float
  changeDubai   Float
  unitIndia     String
  unitDubai     String
  locationIndia String
  locationDubai String
  sparkline     Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id            String        @id @default(uuid())
  buyerId       String
  buyer         User          @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User          @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  totalAmount   Float
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  items         OrderItem[]
  reviews       Review[]
  shipment      Shipment?
  transactions  Transaction[]
  contract      Contract?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Float
  price     Float
}

model Auction {
  id              String        @id @default(uuid())
  creatorId       String
  creator         User          @relation("UserAuctions", fields: [creatorId], references: [id], onDelete: Cascade)
  title           String
  description     String
  cropType        String
  startPrice      Float
  reservePrice    Float
  currentHighBid  Float?
  status          AuctionStatus @default(UPCOMING)
  startTime       DateTime
  endTime         DateTime
  bids            Bid[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Bid {
  id        String    @id @default(uuid())
  auctionId String
  auction   Auction   @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderId  String
  bidder    User      @relation("UserBids", fields: [bidderId], references: [id], onDelete: Cascade)
  bidAmount Float
  status    BidStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Review {
  id          String   @id @default(uuid())
  reviewerId  String
  reviewer    User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId  String
  reviewee    User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      SubscriptionTier
  price     Float
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime
  transactions Transaction[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType @default(INFO)
  createdAt DateTime         @default(now())
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String        @default("New Chat Session")
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" or "assistant"
  content   String
  createdAt DateTime    @default(now())
}

model PricePrediction {
  id              String   @id @default(uuid())
  crop            String
  quantity        Float
  location        String
  expectedPrice   Float
  bestMarket      String
  confidenceScore Float
  trend           String   // "UP", "DOWN", "STABLE"
  createdAt       DateTime @default(now())
}

enum DocumentType {
  PHYTOSANITARY
  BILL_OF_LADING
  CERTIFICATE_OF_ORIGIN
  CUSTOMS_DECLARATION
  COMMERCIAL_INVOICE
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ShipmentStatus {
  BOOKED
  PORT_OF_ORIGIN
  IN_TRANSIT
  PORT_OF_DESTINATION
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model Shipment {
  id                 String          @id @default(uuid())
  orderId            String          @unique
  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingNumber     String          @unique
  carrier            String
  origin             String
  destination        String
  status             ShipmentStatus  @default(BOOKED)
  estimatedDelivery  DateTime?
  actualDelivery     DateTime?
  logisticsBookingId String?
  logisticsBooking   LogisticsBooking? @relation(fields: [logisticsBookingId], references: [id])
  documents          ExportDocument[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model ExportDocument {
  id           String         @id @default(uuid())
  shipmentId   String
  shipment     Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  documentType DocumentType
  fileUrl      String
  status       DocumentStatus @default(PENDING)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

enum LogisticsStatus {
  ASSIGNED
  EN_ROUTE
  DISPATCHED
  DELIVERED
}

model LogisticsBooking {
  id               String          @id @default(uuid())
  driverName       String
  driverPhone      String
  vehicleNumber    String
  vehicleType      String
  status           LogisticsStatus @default(ASSIGNED)
  currentLatitude  Float?
  currentLongitude Float?
  shipments        Shipment[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum PaymentGateway {
  STRIPE
  RAZORPAY
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Transaction {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId          String?
  order            Order?            @relation(fields: [orderId], references: [id])
  subscriptionId   String?
  subscription     Subscription?     @relation(fields: [subscriptionId], references: [id])
  amount           Float
  currency         String            @default("INR")
  gateway          PaymentGateway
  gatewayOrderId   String?
  gatewayPaymentId String?
  status           TransactionStatus @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model SavedSearch {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  filters   Json
  createdAt DateTime @default(now())
}

model PriceAlert {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cropType    String
  targetPrice Float
  condition   String   // "GREATER_THAN" or "LESS_THAN"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Negotiation {
  id            String               @id @default(uuid())
  buyerId       String
  buyer         User                 @relation("BuyerNegotiations", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User                 @relation("SellerNegotiations", fields: [sellerId], references: [id], onDelete: Cascade)
  productId     String
  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  originalPrice Float
  currentPrice  Float
  status        String               @default("PENDING") // "PENDING", "ACCEPTED", "REJECTED"
  messages      NegotiationMessage[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model NegotiationMessage {
  id            String      @id @default(uuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  senderId      String
  content       String
  fileUrl       String?
  createdAt     DateTime    @default(now())
}

model Contract {
  id            String   @id @default(uuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pdfUrl        String
  contractTerms String
  createdAt     DateTime @default(now())
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model SellerVerification {
  id               String             @id @default(uuid())
  userId           String             @unique
  aadharNumber     String?
  gstNumber        String?
  businessCertUrl  String?
  status           VerificationStatus @default(PENDING)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model QualityGrading {
  id             String   @id @default(uuid())
  productId      String   @unique
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  grade          String   // PREMIUM, GRADE_A, GRADE_B, GRADE_C
  labReportUrl   String?
  certificateUrl String?
  imagesUrl      String?
  createdAt      DateTime @default(now())
}

model WarehouseSpace {
  id            String             @id @default(uuid())
  ownerId       String
  name          String
  location      String
  capacityTons  Float
  availableTons Float
  ratePerTonDay Float
  description   String?
  status        String             @default("ACTIVE") // ACTIVE, FULL, ARCHIVED
  bookings      WarehouseBooking[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model WarehouseBooking {
  id           String         @id @default(uuid())
  warehouseId  String
  warehouse    WarehouseSpace @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  farmerId     String
  quantityTons Float
  startDate    DateTime
  endDate      DateTime
  totalCost    Float
  status       String         @default("BOOKED") // BOOKED, IN_STORAGE, COMPLETED, CANCELLED
  createdAt    DateTime       @default(now())
}

model TransportCarrier {
  id            String             @id @default(uuid())
  driverName    String
  driverPhone   String
  vehicleNumber String
  vehicleType   String             // TRUCK, CONTAINER, TEMPO
  capacityTons  Float
  ratePerKm     Float
  activeRoute   String?
  currentStatus String             @default("AVAILABLE") // AVAILABLE, BOOKED, OFFLINE
  bookings      TransportBooking[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model TransportBooking {
  id               String           @id @default(uuid())
  carrierId        String
  carrier          TransportCarrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  userId           String
  fromLocation     String
  toLocation       String
  estimatedKm      Float
  totalCost        Float
  status           String           @default("BOOKED") // BOOKED, IN_TRANSIT, DELIVERED, CANCELLED
  createdAt        DateTime         @default(now())
}

model DemandForecast {
  id                 String   @id @default(uuid())
  cropType           String   @unique
  demandScore        Float    // 0 to 100
  demandLevel        String   // HIGH, MEDIUM, LOW
  opportunityDetails String?
  expectedPriceTrend String   // UP, DOWN, STABLE
  updatedAt          DateTime @updatedAt
}

model BulkRequirement {
  id           String            @id @default(uuid())
  buyerId      String
  cropType     String
  quantityTons Float
  budgetPrice  Float
  deliveryDate DateTime
  status       String            @default("OPEN") // OPEN, CLOSED, FULFILLED
  quotations   FarmerQuotation[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model FarmerQuotation {
  id            String          @id @default(uuid())
  requirementId String
  requirement   BulkRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  farmerId      String
  offeredPrice  Float
  quantityTons  Float
  notes         String?
  status        String          @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt     DateTime        @default(now())
}

model TradeFinanceApplication {
  id                String   @id @default(uuid())
  userId            String
  type              String   // INVOICE_FINANCING, WORKING_CAPITAL, PURCHASE_LOAN
  amount            Float
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED, DISBURSED
  collateralDetails String?
  documentsUrl      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


