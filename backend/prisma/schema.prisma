datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== ENUMS ====================

enum Role {
  FARMER
  BUYER
  EXPORTER
  WAREHOUSE_MANAGER
  TRANSPORTER
  ADMIN
}

enum OrderStatus {
  PENDING
  ESCROW_FUNDED
  DISPATCHED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  ESCROWED
  RELEASED
  REFUNDED
}

enum AuctionStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SubscriptionTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum NotificationType {
  INFO
  ORDER_UPDATE
  BID_UPDATE
  PAYMENT
  PRICE_ALERT
  MARKET_OPPORTUNITY
  FRAUD_ALERT
  AUCTION_OUTBID
  DISPUTE_UPDATE
  WALLET_UPDATE
  SYSTEM
}

enum ProductStatus {
  ACTIVE
  SOLD
  ARCHIVED
}

enum DocumentType {
  PHYTOSANITARY
  BILL_OF_LADING
  CERTIFICATE_OF_ORIGIN
  CUSTOMS_DECLARATION
  COMMERCIAL_INVOICE
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ShipmentStatus {
  BOOKED
  PORT_OF_ORIGIN
  IN_TRANSIT
  PORT_OF_DESTINATION
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum LogisticsStatus {
  ASSIGNED
  EN_ROUTE
  DISPATCHED
  DELIVERED
}

enum PaymentGateway {
  STRIPE
  RAZORPAY
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  MEDIATOR_ASSIGNED
  EVIDENCE_REQUESTED
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
  ESCALATED
}

enum EscrowStatus {
  FUNDED
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum WalletTxnType {
  CREDIT
  DEBIT
  CASHBACK
  WITHDRAWAL
  REFUND
  ESCROW_HOLD
  ESCROW_RELEASE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum PipelineStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSING
  CLOSED_WON
  CLOSED_LOST
}

enum DocCenterType {
  INVOICE
  CONTRACT
  CERTIFICATE
  LAB_REPORT
  OTHER
}

enum AuditCategory {
  AUTH
  ORDER
  PAYMENT
  USER_ACTION
  SECURITY
  SYSTEM
  DISPUTE
  SUBSCRIPTION
  WALLET
}

enum TenantRegion {
  INDIA
  DUBAI
  GLOBAL
}

// ==================== CORE MODELS ====================

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String
  role             Role              @default(BUYER)
  trustScore       Float             @default(80.0)
  tenantRegion     TenantRegion      @default(INDIA)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  profile          Profile?
  products         Product[]         @relation("SellerProducts")
  ordersAsBuyer    Order[]           @relation("BuyerOrders")
  ordersAsSeller   Order[]           @relation("SellerOrders")
  auctions         Auction[]         @relation("UserAuctions")
  bids             Bid[]             @relation("UserBids")
  reviewsGiven     Review[]          @relation("ReviewsGiven")
  reviewsReceived  Review[]          @relation("ReviewsReceived")
  subscriptions    Subscription[]
  notifications    Notification[]
  messagesSent     Message[]         @relation("MessagesSent")
  messagesReceived Message[]         @relation("MessagesReceived")
  refreshTokens    RefreshToken[]
  chatSessions     ChatSession[]
  auditLogs        AuditLog[]
  transactions     Transaction[]
  savedSearches    SavedSearch[]
  priceAlerts      PriceAlert[]
  buyerNegotiations  Negotiation[]   @relation("BuyerNegotiations")
  sellerNegotiations Negotiation[]   @relation("SellerNegotiations")
  wallet           Wallet?
  disputesOpened   Dispute[]         @relation("DisputeOpener")
  disputesAgainst  Dispute[]         @relation("DisputeTarget")
  disputeMessages  DisputeMessage[]
  crmLeadsOwned    CrmLead[]         @relation("LeadOwner")
  crmNotes         CrmNote[]
  followUps        FollowUp[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String?
  companyName String?
  address     String?
  city        String?
  country     String?
  avatarUrl   String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== PRODUCT & MARKET ====================

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                 String        @id @default(uuid())
  sellerId           String
  seller             User          @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId         String
  category           Category      @relation(fields: [categoryId], references: [id])
  title              String
  description        String
  price              Float
  unit               String
  stock              Float
  cropType           String
  grade              String
  imageUrl           String?
  sellerVerification String        @default("Standard")
  status             ProductStatus @default(ACTIVE)
  harvestDate        DateTime?
  certificateUrl     String?
  orderItems         OrderItem[]
  negotiations       Negotiation[]
  qualityGrading     QualityGrading?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model MarketRate {
  id            String   @id @default(uuid())
  crop          String   @unique
  priceIndia    Float
  priceDubai    Float
  changeIndia   Float
  changeDubai   Float
  unitIndia     String
  unitDubai     String
  locationIndia String
  locationDubai String
  sparkline     Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MarketReport {
  id          String   @id @default(uuid())
  type        String
  data        Json
  generatedAt DateTime @default(now())
  @@index([type])
}

// ==================== ORDERS & PAYMENTS ====================

model Order {
  id            String        @id @default(uuid())
  buyerId       String
  buyer         User          @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User          @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  totalAmount   Float
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  items         OrderItem[]
  reviews       Review[]
  shipment      Shipment?
  transactions  Transaction[]
  contract      Contract?
  escrow        Escrow?
  disputes      Dispute[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Float
  price     Float
}

// ==================== ESCROW ====================

model Escrow {
  id             String       @id @default(uuid())
  orderId        String       @unique
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount         Float
  currency       String       @default("INR")
  status         EscrowStatus @default(FUNDED)
  fundedAt       DateTime     @default(now())
  releasedAt     DateTime?
  refundedAt     DateTime?
  gatewayRef     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ==================== WALLET ====================

model Wallet {
  id           String             @id @default(uuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Float              @default(0)
  currency     String             @default("INR")
  transactions WalletTransaction[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model WalletTransaction {
  id          String       @id @default(uuid())
  walletId    String
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        WalletTxnType
  amount      Float
  description String?
  referenceId String?
  createdAt   DateTime     @default(now())
  @@index([walletId])
}

// ==================== DISPUTE RESOLUTION ====================

model Dispute {
  id           String          @id @default(uuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  openedById   String
  openedBy     User            @relation("DisputeOpener", fields: [openedById], references: [id])
  againstId    String
  against      User            @relation("DisputeTarget", fields: [againstId], references: [id])
  reason       String
  description  String
  status       DisputeStatus   @default(OPEN)
  mediatorNote String?
  resolvedAt   DateTime?
  messages     DisputeMessage[]
  evidence     DisputeEvidence[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  @@index([orderId])
  @@index([openedById])
}

model DisputeMessage {
  id         String   @id @default(uuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  content    String
  isMediator Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model DisputeEvidence {
  id         String   @id @default(uuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  fileUrl    String
  fileType   String
  uploadedBy String
  notes      String?
  createdAt  DateTime @default(now())
}

// ==================== CRM ====================

model CrmLead {
  id           String        @id @default(uuid())
  ownerId      String
  owner        User          @relation("LeadOwner", fields: [ownerId], references: [id])
  contactName  String
  contactEmail String?
  contactPhone String?
  company      String?
  source       String?
  status       LeadStatus    @default(NEW)
  stage        PipelineStage @default(PROSPECTING)
  value        Float?
  notes        CrmNote[]
  followUps    FollowUp[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  @@index([ownerId])
  @@index([status])
}

model CrmNote {
  id        String   @id @default(uuid())
  leadId    String
  lead      CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model FollowUp {
  id          String   @id @default(uuid())
  leadId      String
  lead        CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assigneeId  String
  assignee    User     @relation(fields: [assigneeId], references: [id])
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ==================== DOCUMENT CENTER ====================

model Document {
  id          String        @id @default(uuid())
  ownerId     String
  type        DocCenterType
  title       String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  version     Int           @default(1)
  parentId    String?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@index([ownerId])
  @@index([type])
}

// ==================== SUBSCRIPTIONS (SaaS) ====================

model Subscription {
  id             String             @id @default(uuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier           SubscriptionTier
  billingCycle   BillingCycle       @default(MONTHLY)
  price          Float
  status         SubscriptionStatus @default(ACTIVE)
  gateway        PaymentGateway?
  gatewaySubId   String?
  maxProducts    Int                @default(10)
  maxOrders      Int                @default(50)
  maxStorageMb   Int                @default(500)
  analyticsAccess Boolean           @default(false)
  startDate      DateTime           @default(now())
  endDate        DateTime
  transactions   Transaction[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

// ==================== FEATURE FLAGS ====================

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  percentage  Int      @default(100)
  roles       String[]
  regions     String[]
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([key])
}

// ==================== TENANT CONFIG ====================

model TenantConfig {
  id             String       @id @default(uuid())
  region         TenantRegion @unique
  currency       String
  currencySymbol String
  taxRate        Float        @default(0)
  timezone       String
  supportEmail   String?
  settings       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ==================== AUDIT LOGS (Enhanced) ====================

model AuditLog {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  category  AuditCategory @default(USER_ACTION)
  resource  String?
  resourceId String?
  details   String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime      @default(now())
  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

// ==================== EXISTING MODELS (preserved) ====================

model FraudAlert {
  id         String   @id @default(uuid())
  userId     String
  alertType  String
  severity   String
  details    String
  isResolved Boolean  @default(false)
  resolvedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([userId])
  @@index([isResolved])
}

model Auction {
  id              String        @id @default(uuid())
  creatorId       String
  creator         User          @relation("UserAuctions", fields: [creatorId], references: [id], onDelete: Cascade)
  title           String
  description     String
  cropType        String
  startPrice      Float
  reservePrice    Float
  currentHighBid  Float?
  status          AuctionStatus @default(UPCOMING)
  startTime       DateTime
  endTime         DateTime
  bids            Bid[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Bid {
  id        String    @id @default(uuid())
  auctionId String
  auction   Auction   @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderId  String
  bidder    User      @relation("UserBids", fields: [bidderId], references: [id], onDelete: Cascade)
  bidAmount Float
  status    BidStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Review {
  id          String   @id @default(uuid())
  reviewerId  String
  reviewer    User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId  String
  reviewee    User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType @default(INFO)
  createdAt DateTime         @default(now())
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String        @default("New Chat Session")
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime    @default(now())
}

model PricePrediction {
  id              String   @id @default(uuid())
  crop            String
  quantity        Float
  location        String
  expectedPrice   Float
  bestMarket      String
  confidenceScore Float
  trend           String
  createdAt       DateTime @default(now())
}

model Shipment {
  id                 String          @id @default(uuid())
  orderId            String          @unique
  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingNumber     String          @unique
  carrier            String
  origin             String
  destination        String
  status             ShipmentStatus  @default(BOOKED)
  estimatedDelivery  DateTime?
  actualDelivery     DateTime?
  logisticsBookingId String?
  logisticsBooking   LogisticsBooking? @relation(fields: [logisticsBookingId], references: [id])
  documents          ExportDocument[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model ExportDocument {
  id           String         @id @default(uuid())
  shipmentId   String
  shipment     Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  documentType DocumentType
  fileUrl      String
  status       DocumentStatus @default(PENDING)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model LogisticsBooking {
  id               String          @id @default(uuid())
  driverName       String
  driverPhone      String
  vehicleNumber    String
  vehicleType      String
  status           LogisticsStatus @default(ASSIGNED)
  currentLatitude  Float?
  currentLongitude Float?
  shipments        Shipment[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Transaction {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId          String?
  order            Order?            @relation(fields: [orderId], references: [id])
  subscriptionId   String?
  subscription     Subscription?     @relation(fields: [subscriptionId], references: [id])
  amount           Float
  currency         String            @default("INR")
  gateway          PaymentGateway
  gatewayOrderId   String?
  gatewayPaymentId String?
  status           TransactionStatus @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model SavedSearch {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  filters   Json
  createdAt DateTime @default(now())
}

model PriceAlert {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cropType    String
  targetPrice Float
  condition   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Negotiation {
  id            String               @id @default(uuid())
  buyerId       String
  buyer         User                 @relation("BuyerNegotiations", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User                 @relation("SellerNegotiations", fields: [sellerId], references: [id], onDelete: Cascade)
  productId     String
  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  originalPrice Float
  currentPrice  Float
  status        String               @default("PENDING")
  messages      NegotiationMessage[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model NegotiationMessage {
  id            String      @id @default(uuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  senderId      String
  content       String
  fileUrl       String?
  createdAt     DateTime    @default(now())
}

model Contract {
  id            String   @id @default(uuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pdfUrl        String
  contractTerms String
  createdAt     DateTime @default(now())
}

model SellerVerification {
  id               String             @id @default(uuid())
  userId           String             @unique
  aadharNumber     String?
  gstNumber        String?
  businessCertUrl  String?
  status           VerificationStatus @default(PENDING)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model QualityGrading {
  id             String   @id @default(uuid())
  productId      String   @unique
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  grade          String
  labReportUrl   String?
  certificateUrl String?
  imagesUrl      String?
  createdAt      DateTime @default(now())
}

model WarehouseSpace {
  id            String             @id @default(uuid())
  ownerId       String
  name          String
  location      String
  capacityTons  Float
  availableTons Float
  ratePerTonDay Float
  description   String?
  status        String             @default("ACTIVE")
  bookings      WarehouseBooking[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model WarehouseBooking {
  id           String         @id @default(uuid())
  warehouseId  String
  warehouse    WarehouseSpace @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  farmerId     String
  quantityTons Float
  startDate    DateTime
  endDate      DateTime
  totalCost    Float
  status       String         @default("BOOKED")
  createdAt    DateTime       @default(now())
}

model TransportCarrier {
  id            String             @id @default(uuid())
  driverName    String
  driverPhone   String
  vehicleNumber String
  vehicleType   String
  capacityTons  Float
  ratePerKm     Float
  activeRoute   String?
  currentStatus String             @default("AVAILABLE")
  bookings      TransportBooking[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model TransportBooking {
  id               String           @id @default(uuid())
  carrierId        String
  carrier          TransportCarrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  userId           String
  fromLocation     String
  toLocation       String
  estimatedKm      Float
  totalCost        Float
  status           String           @default("BOOKED")
  createdAt        DateTime         @default(now())
}

model DemandForecast {
  id                 String   @id @default(uuid())
  cropType           String   @unique
  demandScore        Float
  demandLevel        String
  opportunityDetails String?
  expectedPriceTrend String
  updatedAt          DateTime @updatedAt
}

model BulkRequirement {
  id           String            @id @default(uuid())
  buyerId      String
  cropType     String
  quantityTons Float
  budgetPrice  Float
  deliveryDate DateTime
  status       String            @default("OPEN")
  quotations   FarmerQuotation[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model FarmerQuotation {
  id            String          @id @default(uuid())
  requirementId String
  requirement   BulkRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  farmerId      String
  offeredPrice  Float
  quantityTons  Float
  notes         String?
  status        String          @default("PENDING")
  createdAt     DateTime        @default(now())
}

model TradeFinanceApplication {
  id                String   @id @default(uuid())
  userId            String
  type              String
  amount            Float
  status            String   @default("PENDING")
